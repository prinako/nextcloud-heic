# Database configuration
# WARNING: Replace ALL placeholder values with strong, randomly generated passwords before use.
# You can generate a secure password with: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Nextcloud admin credentials
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Trusted domains (space-separated list, e.g. "localhost example.com")
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# Port to expose Nextcloud on the host (default: 8080)
NEXTCLOUD_PORT=8080
